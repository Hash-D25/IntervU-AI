# Root-level infrastructure variables consumed by docker-compose.
# Copy to `.env` and adjust as needed:  cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=interviewerai
POSTGRES_PASSWORD=interviewerai
POSTGRES_DB=interviewerai
POSTGRES_PORT=5432

# --- ChromaDB ---
# Host port is 8001 to avoid clashing with the backend on 8000.
CHROMA_PORT=8001
