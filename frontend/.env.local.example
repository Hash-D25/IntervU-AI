# Frontend configuration. Copy to `.env.local`:  cp .env.local.example .env.local

# Base URL of the backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Google OAuth 2.0 Web client ID (must match backend GOOGLE_CLIENT_ID).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Vercel production (set in Project → Settings → Environment Variables) ---
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.example.com/api/v1
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
#
# Also configure:
# - Vercel project Root Directory: frontend (if using frontend/vercel.json)
# - Backend CORS_ORIGINS: include your https://*.vercel.app origin
# - Google OAuth authorized origins: include your Vercel deployment URL