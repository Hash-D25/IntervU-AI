# Backend configuration. Copy to `.env`:  cp .env.example .env
# All settings are read via pydantic-settings (see app/core/config).

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# --- Database ---
# psycopg3 async driver.
DATABASE_URL=postgresql+psycopg://interviewerai:interviewerai@localhost:5432/interviewerai

# --- Authentication / JWT ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-generate-a-32-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI provider (OpenAI-compatible) ---
# BASE_URL lets you point at any OpenAI-compatible endpoint (OpenAI, local, etc.).
LLM_PROVIDER=openai
LLM_API_KEY=changeme
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Vector store (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- Voice / transcription (Whisper) ---
WHISPER_MODEL=base
