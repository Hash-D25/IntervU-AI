# Backend configuration. Copy to `.env`:  cp .env.example .env
# All settings are read via pydantic-settings (see app/core/config).

# --- Application ---
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
# Comma-separated browser origins (production). In development, any localhost port is allowed.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database ---
# psycopg3 async driver.
DATABASE_URL=postgresql+psycopg://interviewerai:interviewerai@localhost:5432/interviewerai

# --- Authentication / JWT ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-generate-a-32-byte-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Resume uploads ---
# local = disk under RESUME_UPLOAD_DIR; cloudinary = Cloudinary raw uploads
RESUME_STORAGE_BACKEND=local
RESUME_UPLOAD_DIR=uploads
RESUME_MAX_SIZE_MB=5
# hybrid = rules first + LLM gap-fill (recommended); llm = full LLM parse
RESUME_PARSER=hybrid
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- LLM provider ---
# Recommended: Groq primary (fast). Ollama fallback (free, local).
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.1-8b-instant

LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_API_KEY=ollama
LLM_FALLBACK_BASE_URL=http://localhost:11434/v1
LLM_FALLBACK_MODEL=qwen3:8b

# Speed tuning
LLM_MAX_RESUME_CHARS=6000
LLM_MAX_JD_CHARS=8000
LLM_NUM_PREDICT=800
LLM_DISABLE_THINKING=true
LLM_PRIMARY_TIMEOUT_SECONDS=15

# Job description analysis (llm = LLM-based extraction)
JOB_DESCRIPTION_ANALYZER=llm
JOB_DESCRIPTION_MAX_SIZE_MB=5

# Interview question generation (llm = LLM-based strategies)
QUESTION_GENERATOR=llm

# Answer evaluation (llm = LLM-based scoring)
ANSWER_EVALUATOR=llm

# Feedback report generation (llm = LLM-based coach report)
FEEDBACK_GENERATOR=llm

# Follow-up probing (llm | none)
FOLLOW_UP_GENERATOR=llm
MAX_FOLLOW_UPS_PER_ANSWER=1
MAX_FOLLOW_UPS_PER_INTERVIEW=3
FOLLOW_UP_ON_PHASES=resume,projects,cs_fundamentals,behavioral

# Interview memory (session = rebuild from answers; none = disabled)
INTERVIEW_MEMORY=session
INTERVIEW_MEMORY_MAX_ANSWERS=8
INTERVIEW_MEMORY_EXCERPT_CHARS=280

# --- Voice / transcription ---
# fake = deterministic dev/test; whisper = faster-whisper (requires pip install -e ".[voice]")
TRANSCRIBER=fake
WHISPER_MODEL=base
VOICE_MAX_SIZE_MB=25
# Leave empty for auto language detection
WHISPER_LANGUAGE=
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
ENABLE_VAD=true
MAX_AUDIO_DURATION_SECONDS=300
SUPPORTED_AUDIO_FORMATS=wav,mp3,m4a,webm,ogg
RETURN_WORD_TIMESTAMPS=false
WHISPER_BEAM_SIZE=5
TRANSCRIPT_REFINER=llm

# Gemini
# LLM_PROVIDER=gemini
# LLM_API_KEY=AIza...
# LLM_MODEL=gemini-2.0-flash
# LLM_FALLBACK_PROVIDER=

# OpenAI (paid)
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_FALLBACK_PROVIDER=

# --- Vector store (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Disable fallback: LLM_FALLBACK_PROVIDER=
